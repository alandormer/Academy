DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/academy_knowledge
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_LOCAL_FILES_ONLY=true
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=6

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_RAW=academy-raw
MINIO_BUCKET_AUDIO=academy-audio
MINIO_BUCKET_EXPORTS=academy-exports

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
